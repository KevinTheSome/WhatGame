{
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
        "output": "static"
    },
    "plugins": [
        [
            "expo-router",
            {
                "origin": "https://n"
            }
        ],
        [
            "expo-secure-store",
            {
                "configureAndroidBackup": true,
                "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
            }
        ]
    ],
    "name": "WhatGameApp",
    "slug": "What-Game-App"
}
